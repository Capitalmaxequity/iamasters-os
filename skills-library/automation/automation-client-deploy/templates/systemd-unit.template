# {{SERVICE_NAME}}.service — generated by automation-client-deploy
# Use this when you want the app to run on a Linux box WITHOUT Docker
# (a plain venv on a VPS). Install steps:
#
#   sudo cp {{SERVICE_NAME}}.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now {{SERVICE_NAME}}
#   systemctl status {{SERVICE_NAME}}          # verify
#   journalctl -u {{SERVICE_NAME}} -f          # live logs
#
# Secrets stay in {{APP_DIR}}/.env (chmod 600), never in this unit file.

[Unit]
Description={{SERVICE_DESCRIPTION}}
After=network-online.target
Wants=network-online.target
# If it needs a local Ollama running as its own service, uncomment:
# After=network-online.target ollama.service
# Requires=ollama.service

[Service]
Type=simple
User={{RUN_USER}}                       # a dedicated non-root user, e.g. "dev"
WorkingDirectory={{APP_DIR}}
EnvironmentFile={{APP_DIR}}/.env
# Run through the venv's python so deps resolve. Create it once:
#   python3 -m venv .venv && .venv/bin/pip install -r requirements.txt
ExecStart={{APP_DIR}}/.venv/bin/python {{ENTRYPOINT}}

Restart=always
RestartSec=5

# Basic hardening — safe defaults for a small service.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
# Let the app write only where it must (its data dir):
ReadWritePaths={{APP_DIR}}

# Cap the journal noise.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
