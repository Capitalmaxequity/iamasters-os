# docker-compose.yml — generated by automation-client-deploy
# Replace every {{PLACEHOLDER}}. Delete the blocks you don't need.
# This is the recommended package for a VPS / Linux server target.
# For a non-technical client's desktop PC, prefer the native install path
# (run.bat / systemd is overkill there — see the skill's archetype B).

services:
  {{SERVICE_NAME}}:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{SERVICE_NAME}}:latest
    container_name: {{SERVICE_NAME}}
    restart: unless-stopped        # survives reboots; "no" while debugging

    # Secrets live ONLY here, on the server, never in the image or git.
    # Copy .env.example -> .env on the server and fill it before "up".
    env_file:
      - .env

    # Persist anything the app writes (DB, uploads). Without this you LOSE
    # data on every redeploy. Left side = host path, right side = container path.
    volumes:
      - ./data:/app/data           # e.g. SQLite file, generated files
      # - ./logs:/app/logs

    # Only if the app exposes HTTP. A poll-based bot needs NO ports.
    # ports:
    #   - "127.0.0.1:{{HOST_PORT}}:{{CONTAINER_PORT}}"   # bind to localhost; put a reverse proxy in front

    # Health check lets `docker ps` and the deploy script know it's really up.
    # Swap for a real check: curl an endpoint, or `pgrep -f main.py` for a worker.
    healthcheck:
      test: ["CMD-SHELL", "{{HEALTHCHECK_CMD}}"]   # e.g. curl -f http://localhost:8000/health || exit 1
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

    # Stop the logs from filling the disk on a small VPS.
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # --- Optional: local LLM via Ollama, if the app needs it on the same box ---
  # Only worth it on a server with enough RAM. On a tiny VPS, point the app at a
  # hosted model instead. On the CLIENT's own PC, install Ollama natively.
  # ollama:
  #   image: ollama/ollama:latest
  #   container_name: {{SERVICE_NAME}}-ollama
  #   restart: unless-stopped
  #   volumes:
  #     - ollama-models:/root/.ollama
  #   # GPU is optional; CPU-only works for small models.

